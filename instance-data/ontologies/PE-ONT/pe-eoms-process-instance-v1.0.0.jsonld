    {"_section": "=== PHASE 8: APP FRAMEWORK & DS INTEGRATION (Epic 8) ==="},

    {
      "@type": "pe:ProcessPhase",
      "@id": "pe:eoms-phase-8-framework",
      "phaseId": "EOMS-PH-8",
      "phaseName": "App Framework & DS Integration",
      "epicRef": "Epic 8",
      "phaseOrder": 0,
      "status": "in_progress",
      "startDate": "2026-02-23",
      "endDate": null,
      "description": "DS-ONT instance, application skeleton, token bridge, admin overlay. Cross-cutting — feeds UI for all other epics.",
      "deliverables": ["DS-ONT instance (90+ tokens)", "App skeleton (8 zones, 6 nav, 10 actions)", "Token bridge (DS→shadcn CSS vars)", "Admin overlay", "Brand refinement workflow"],
      "dsInstanceRef": "ds:eoms-endeavour-ds-instance-v1.0.0"
    },

    {
      "@type": "pe:Activity",
      "@id": "pe:eoms-f8.1-ds-instance",
      "activityId": "F8.1",
      "activityName": "DS-ONT Instance",
      "featureRef": "F8.1",
      "status": "completed",
      "stories": [
        {"storyId": "S8.1.1", "name": "Primitive tokens (colours, typography, spacing, radius)", "status": "done", "testContract": {"type": "unit", "validates": "90+ primitive tokens parse from JSONLD"}},
        {"storyId": "S8.1.2", "name": "Semantic tokens (7 intent groups)", "status": "done", "testContract": {"type": "unit", "validates": "50+ semantic tokens resolve to primitives"}},
        {"storyId": "S8.1.3", "name": "BrandVariant entity for Endeavour Meats", "status": "done", "testContract": {"type": "unit", "validates": "BrandVariant 'endeavour' loads with correct metadata"}},
        {"storyId": "S8.1.4", "name": "ThemeMode entity (light default)", "status": "done", "testContract": {"type": "unit", "validates": "ThemeMode 'light' is default; resolves all semantic tokens"}},
        {"storyId": "S8.1.5", "name": "Validate against DS-ONT v3.0.0 schema", "status": "done", "testContract": {"type": "unit", "validates": "JSONLD validates against DS-ONT schema; no missing required fields"}}
      ],
      "acceptanceCriteria": "DS-ONT instance valid, 90+ tokens, 7 semantic groups, Endeavour brand"
    },

