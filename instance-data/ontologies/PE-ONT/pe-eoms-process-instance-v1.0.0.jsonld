      "featureRef": "F2.2",
      "status": "not_started",
      "stories": [
        {"storyId": "US-2.2.1", "name": "View full product details with eligibility flags", "status": "not_started", "testContract": {"type": "unit", "validates": "Product detail renders all fields; eligibility icons shown"}},
        {"storyId": "US-2.2.2", "name": "Product codes in monospace font", "status": "not_started", "testContract": {"type": "unit", "validates": "Product code element uses ds:fontFamily.mono token"}}
      ],
      "acceptanceCriteria": "Product details render correctly with eligibility and correct typography"
    },

    {"_section": "=== PHASE 3: ORDER EXPORT (Epic 3-Export) ==="},

    {
      "@type": "pe:ProcessPhase",
      "@id": "pe:eoms-phase-3-export",
      "phaseId": "EOMS-PH-3",
      "phaseName": "Order Export to Finance",
      "epicRef": "Epic 3 (Export)",
