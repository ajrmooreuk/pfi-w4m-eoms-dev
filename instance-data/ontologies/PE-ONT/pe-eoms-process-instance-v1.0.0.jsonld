        {"storyId": "US-3.2.2", "name": "Format compatible with finance system import", "status": "not_started", "testContract": {"type": "integration", "validates": "Finance system accepts exported file without error"}},
        {"storyId": "US-3.2.3", "name": "Choose between CSV and JSON formats", "status": "not_started", "testContract": {"type": "unit", "validates": "Both CSV and JSON options available; both valid"}}
      ],
      "acceptanceCriteria": "Export format matches finance requirements; CSV and JSON both valid"
    },

