  "tddSpecification": {
    "description": "Test-Driven Design specification derived from this PE process instance. Every story's testContract defines the test type and validation criteria. The builder generates test stubs from these contracts before implementation begins.",
    "testLevels": [
      {"level": "unit", "source": "story.testContract[type=unit]", "count": 25, "description": "Individual component/function tests per story"},
      {"level": "integration", "source": "story.testContract[type=integration]", "count": 18, "description": "Cross-component flow tests per feature"},
      {"level": "performance", "source": "story.testContract[type=performance]", "count": 1, "description": "Latency/throughput tests"},
      {"level": "uat", "source": "story.testContract[type=uat]", "count": 3, "description": "User acceptance test scenarios"},
      {"level": "coverage", "source": "story.testContract[type=coverage]", "count": 1, "description": "Code coverage threshold tests"},
      {"level": "gate", "source": "ProcessGate entities", "count": 5, "description": "Phase progression quality gates (G1–G5)"}
    ],
    "tddWorkflow": [
      "1. Builder reads PE process instance",
      "2. For each Activity (feature), extract story testContracts",
      "3. Generate test stubs (failing) from testContract.validates",
      "4. Implement feature code to make tests pass",
      "5. Run gate tests before phase progression",
      "6. Mark Activity and Phase status as completed"
    ],
    "sopDomainMapping": "testContracts reference SOP-ONT entities via sopEntity field — ensures tests validate domain model compliance, not just UI behaviour"
  }
}
