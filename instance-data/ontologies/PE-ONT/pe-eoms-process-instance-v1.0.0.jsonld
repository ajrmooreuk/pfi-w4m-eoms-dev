    },

    {"_section": "=== PHASE 1: ORDER MANAGEMENT (Epic 1) ==="},

    {
      "@type": "pe:ProcessPhase",
      "@id": "pe:eoms-phase-1-order-mgmt",
      "phaseId": "EOMS-PH-1",
      "phaseName": "Order Management",
      "epicRef": "Epic 1",
      "phaseOrder": 2,
      "status": "in_progress",
      "startDate": "2026-03-10",
      "endDate": null,
      "description": "Order creation wizard, line items, order lifecycle. File-based JSON before DB. Core SOP-ONT process execution.",
      "deliverables": ["Order creation wizard", "Product search in order context", "Order lifecycle (Draft→Complete→Exported)", "Order list with status filtering"],
      "pbsRefs": ["PBS-2.0", "PBS-3.0"],
      "sopProcessMapping": "SalesOrderProcess lifecycle: CustomerEnquiry → SalesQuotation → OrderCapture → OrderValidation → CreditCheck"
    },

    {
      "@type": "pe:Activity",
      "@id": "pe:eoms-f1.1-order-wizard",
      "activityId": "F1.1",
      "activityName": "Order Creation Wizard",
      "featureRef": "F1.1",
      "status": "not_started",
      "description": "Create new export order with customer, shipping, container, incoterms. Maps to SOP: CustomerEnquiry → SalesQuotation → OrderCapture.",
      "sopEntityMapping": [
        "Wizard Step 1 (Customer) → sop:CustomerEnquiry + sop:CustomerAccount",
        "Wizard Step 2 (Shipping) → sop:SalesChannel + lsc:SupplyChain",
        "Wizard Step 3 (Products) → sop:QuotationLine + org-ctx:Product",
        "Wizard Submit → sop:OrderCapture"
      ],
      "stories": [
        {"storyId": "US-1.1.1", "name": "Create new export order with customer/shipping", "status": "not_started", "testContract": {"type": "integration", "validates": "Order created with customer + shipping fields; persisted to JSON/DB", "sopEntity": "sop:OrderCapture"}},
        {"storyId": "US-1.1.2", "name": "Search and select from existing customers", "status": "not_started", "testContract": {"type": "unit", "validates": "Customer search returns matches; selection populates order", "sopEntity": "sop:CustomerAccount"}},
        {"storyId": "US-1.1.3", "name": "Specify container type, incoterms, shipping dates", "status": "not_started", "testContract": {"type": "unit", "validates": "Container/incoterms/dates stored on order; validated", "sopEntity": "sop:SalesChannel"}},
        {"storyId": "US-1.1.4", "name": "Save order as draft to complete later", "status": "not_started", "testContract": {"type": "integration", "validates": "Draft order persists; reloadable; editable", "sopEntity": "sop:OrderCapture[status=draft]"}},
        {"storyId": "US-1.1.5", "name": "Select supplier and establishment number", "status": "not_started", "testContract": {"type": "unit", "validates": "Supplier selection from catalogue; establishment number validated"}}
      ],
      "acceptanceCriteria": "Trader can create order with customer, shipping, products; save as draft; resume later"
    },

    {
      "@type": "pe:Activity",
      "@id": "pe:eoms-f1.2-line-items",
      "activityId": "F1.2",
      "activityName": "Order Line Items",
      "featureRef": "F1.2",
      "status": "not_started",
      "description": "Add/edit/remove products on order with quantity and pricing. Maps to SOP: QuotationLine with product catalogue cross-ref.",
      "sopEntityMapping": [
        "Line item add → sop:QuotationLine (quantity, unitPrice, currency)",
        "Product search → org-ctx:Product (code, description, brand)",
        "Market eligibility → org-ctx:MarketSegment cross-ref",
        "Line total → sop:QuotationLine.lineValue"
      ],
      "stories": [
        {"storyId": "US-1.2.1", "name": "Add products with quantity and pricing", "status": "not_started", "testContract": {"type": "unit", "validates": "Product added to order; quantity × unitPrice = lineValue", "sopEntity": "sop:QuotationLine"}},
        {"storyId": "US-1.2.2", "name": "Search 7,816+ products by code/description/brand", "status": "not_started", "testContract": {"type": "integration", "validates": "Search returns matches < 200ms; 7,816 products indexed", "sopEntity": "org-ctx:Product"}},
        {"storyId": "US-1.2.3", "name": "See market eligibility for selected products", "status": "not_started", "testContract": {"type": "unit", "validates": "Eligibility flags shown per destination country", "sopEntity": "org-ctx:MarketSegment"}},
        {"storyId": "US-1.2.4", "name": "Edit or remove line items before completing", "status": "not_started", "testContract": {"type": "unit", "validates": "Line edit updates totals; line remove recalculates order value"}}
      ],
      "acceptanceCriteria": "Products searchable; line items CRUD works; totals recalculate; market eligibility visible"
    },

    {
      "@type": "pe:Activity",
      "@id": "pe:eoms-f1.3-lifecycle",
      "activityId": "F1.3",
      "activityName": "Order Lifecycle",
      "featureRef": "F1.3",
      "status": "not_started",
      "description": "Order state transitions: Draft → Complete → Exported. Maps to SOP: OrderValidation → CreditCheck → validatedOrderToFulfilment bridge.",
      "sopEntityMapping": [
        "Mark Complete → sop:OrderValidation (validates order completeness)",
        "Credit check → sop:CreditCheck (automated or manual)",
        "Order list → sop:SalesOrderProcess collection view",
        "Validated → sop:validatedOrderToFulfilment → ofm:SalesOrder (future bridge)"
      ],
      "stories": [
        {"storyId": "US-1.3.1", "name": "Mark order as complete", "status": "not_started", "testContract": {"type": "integration", "validates": "Order transitions Draft→Complete; validation rules fire", "sopEntity": "sop:OrderValidation"}},
        {"storyId": "US-1.3.2", "name": "View list of all orders with status filtering", "status": "not_started", "testContract": {"type": "integration", "validates": "Order list loads; filter by status works; pagination works"}},
        {"storyId": "US-1.3.3", "name": "View full details and history of any order", "status": "not_started", "testContract": {"type": "integration", "validates": "Order detail shows all fields, line items, audit trail"}},
        {"storyId": "US-1.3.4", "name": "Edit a draft order", "status": "not_started", "testContract": {"type": "integration", "validates": "Draft order editable; Complete order not editable"}}
      ],
      "acceptanceCriteria": "Full order lifecycle: create → draft → edit → complete → view history"
    },

