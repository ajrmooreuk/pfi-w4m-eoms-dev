  "oaa:clientRef": "emc:InstanceConfiguration-W4M-EOMS",
  "oaa:created": "2026-03-10",
  "oaa:description": "PE-ONT process instance for W4M EOMS — maps the complete programme plan (7 epics, 17 features, 53 stories) to PE-ONT Process, ProcessPhase, ProcessGate, and Activity entities. Enables TDD: each feature/story becomes a testable process activity with acceptance criteria, input/output contracts, and gate conditions. SOP-ONT entities are the domain model; this PE instance is the process execution model that drives builder test generation.",

  "metadata": {
    "title": "W4M-EOMS PE Process Instance — Order Management Lifecycle",
    "version": "1.0.0",
    "created": "2026-03-10",
    "author": "PF-Core Platform Team",
    "owningInstance": "PFI-W4M-EOMS",
    "sourceOntology": "PE-ONT v4.0.0",
    "oaaVersion": "7.0.0",
    "programmeRef": "PFI-EOMS-PLAN-Programme-Status-v1.0.0",
    "goLiveTarget": "2026-04-18",
    "tddNote": "Every Activity entity below has acceptanceCriteria and testContract fields. The builder uses these to generate: (1) unit tests per story, (2) integration tests per feature, (3) gate tests per epic. ProcessGate entities define the quality thresholds that must pass before phase progression."
  },

  "entities": [

    {"_section": "=== ROOT PROCESS: EOMS ORDER MANAGEMENT PLATFORM ==="},

    {
      "@type": "pe:Process",
      "@id": "pe:eoms-process-root",
      "processId": "EOMS-PROC-001",
      "processName": "EOMS Order Management Platform Delivery",
      "processType": "development",
      "description": "End-to-end delivery of the Endeavour Order Management System — from foundation infrastructure through order management, product catalogue, export, UAT, and go-live. Maps 1:1 to the EOMS programme plan. Each epic = ProcessPhase, each feature = Activity group, each story = Activity.",
      "businessObjective": "Replace manual Excel-based export order management with AI-enabled platform supporting 2x revenue growth ($600M→$1.2Bn) without proportional headcount increase",
      "scope": "Phase 1: Order creation, product catalogue, order export, UAT, deployment. Excludes FX (Phase 3), AI agents (Phase 2), dashboards (Phase 4).",
      "owner": "wings4mind.ai",
      "status": "active",
      "version": "1.0.0",
      "estimatedDuration": "P8W",
      "automationLevel": 40,
      "sopGraphRef": "sop:SalesOrderProcess",
      "emcInstanceRef": "emc:InstanceConfiguration-W4M-EOMS"
    },

    {"_section": "=== PHASE 0: FOUNDATION & INFRASTRUCTURE (Epic 0) ==="},

    {
      "@type": "pe:ProcessPhase",
      "@id": "pe:eoms-phase-0-foundation",
      "phaseId": "EOMS-PH-0",
      "phaseName": "Foundation & Infrastructure",
      "epicRef": "Epic 0",
      "phaseOrder": 1,
      "status": "completed",
      "startDate": "2026-02-23",
      "endDate": "2026-03-07",
      "description": "Environment setup, database schema, authentication, design system, data import. Gate G1 passed.",
      "deliverables": ["Supabase project", "DB schemas (order/product/customer)", "RLS policies", "Supabase Auth", "RBAC (Trader/Admin)", "Endeavour DS tokens", "Test data imported (7,635 lines)"],
      "pbsRefs": ["PBS-1.0", "PBS-2.0", "PBS-6.0"]
    },

    {
      "@type": "pe:Activity",
      "@id": "pe:eoms-f0.1-env-setup",
      "activityId": "F0.1",
      "activityName": "Environment Setup",
      "featureRef": "F0.1",
      "status": "in_progress",
      "description": "Set up Supabase, Vercel, dev/staging/prod environments",
      "stories": [
        {"storyId": "US-0.1.1", "name": "Set up Supabase project (Sydney)", "status": "done", "testContract": {"type": "integration", "validates": "Supabase connection from Next.js API route"}},
        {"storyId": "US-0.1.2", "name": "Set up Vercel deployment pipeline", "status": "done", "testContract": {"type": "integration", "validates": "Vercel deploy on push to main"}},
        {"storyId": "US-0.1.3", "name": "Configure dev/staging/prod environments", "status": "done", "testContract": {"type": "integration", "validates": "Environment variable isolation per stage"}},
        {"storyId": "US-0.1.4", "name": "Client Supabase project setup — shared Gmail", "status": "blocked", "blocker": "Needs shared Gmail for client-owned Supabase", "testContract": {"type": "integration", "validates": "Client Supabase accessible with RLS"}}
      ],
      "acceptanceCriteria": "All environments reachable; Supabase responds; Vercel deploys on push"
    },

    {
      "@type": "pe:Activity",
      "@id": "pe:eoms-f0.2-db-schema",
      "activityId": "F0.2",
      "activityName": "Database Schema",
      "featureRef": "F0.2",
      "status": "completed",
      "description": "Order, product, customer DB schemas with RLS and audit logging",
      "sopEntityMapping": ["sop:CustomerAccount → customers table", "sop:SalesOrderProcess → orders table", "sop:QuotationLine → order_lines table"],
      "stories": [
        {"storyId": "US-0.2.1", "name": "Implement order/product/customer DB schemas", "status": "done", "testContract": {"type": "unit", "validates": "Schema DDL executes without error; tables exist"}},
        {"storyId": "US-0.2.2", "name": "Configure Row Level Security policies", "status": "done", "testContract": {"type": "integration", "validates": "RLS blocks cross-tenant reads"}},
        {"storyId": "US-0.2.3", "name": "Set up audit logging tables", "status": "done", "testContract": {"type": "integration", "validates": "INSERT/UPDATE triggers fire audit rows"}}
      ],
      "acceptanceCriteria": "All tables created; RLS active; audit triggers fire on mutations"
    },

    {
      "@type": "pe:Activity",
      "@id": "pe:eoms-f0.3-auth",
      "activityId": "F0.3",
      "activityName": "Authentication & RBAC",
      "featureRef": "F0.3",
      "status": "completed",
      "description": "Supabase Auth with email/password and 2-role RBAC (Trader, Admin)",
      "stories": [
        {"storyId": "US-0.3.1", "name": "Implement Supabase Auth (email/password)", "status": "done", "testContract": {"type": "integration", "validates": "Sign-up, sign-in, sign-out flows work"}},
        {"storyId": "US-0.3.2", "name": "Configure RBAC (Trader, Admin)", "status": "done", "testContract": {"type": "integration", "validates": "Trader cannot access admin routes; Admin can access all"}}
      ],
      "acceptanceCriteria": "Auth flow works end-to-end; RBAC enforced on protected routes"
    },

    {
      "@type": "pe:Activity",
      "@id": "pe:eoms-f0.4-design-system",
      "activityId": "F0.4",
      "activityName": "Design System",
      "featureRef": "F0.4",
      "status": "completed",
      "description": "Endeavour-DS brand tokens and shadcn/ui component library",
      "dsInstanceRef": "ds:eoms-endeavour-ds-instance-v1.0.0",
      "stories": [
        {"storyId": "US-0.4.1", "name": "Create Endeavour-DS brand tokens", "status": "done", "testContract": {"type": "unit", "validates": "90+ tokens parse from JSONLD; semantic tokens resolve"}},
        {"storyId": "US-0.4.2", "name": "Build core shadcn/ui component library", "status": "done", "testContract": {"type": "unit", "validates": "Button, Input, Card, Dialog render with DS tokens"}}
      ],
      "acceptanceCriteria": "DS-ONT instance valid; shadcn components render with Endeavour branding"
    },

    {
      "@type": "pe:Activity",
      "@id": "pe:eoms-f0.5-data-import",
      "activityId": "F0.5",
      "activityName": "Data Import",
      "featureRef": "F0.5",
      "status": "completed",
      "description": "Import product catalogue (7,816 codes) and anonymised test orders (7,635 lines)",
      "sopEntityMapping": ["CSV.Buyer_Name_Alias → sop:CustomerAccount", "CSV.Order-Anon → sop:SalesOrderProcess", "CSV.Code+Description+Quantity+UnitPrice → sop:QuotationLine"],
      "stories": [
        {"storyId": "US-0.5.1", "name": "Import product catalogue (7,816 codes)", "status": "done", "testContract": {"type": "integration", "validates": "7,816 products in DB; searchable by code and description"}},
        {"storyId": "US-0.5.2", "name": "Import sample customer data", "status": "done", "testContract": {"type": "integration", "validates": "Customer records match distinct Buyer aliases from CSV"}},
        {"storyId": "US-0.5.4", "name": "Import anonymised sale order test data (7,635 lines)", "status": "done", "testContract": {"type": "integration", "validates": "7,635 order line items loaded; totals match CSV"}}
      ],
      "acceptanceCriteria": "Product catalogue searchable; customer data loaded; order lines match CSV count"
    },

    {"_section": "=== GATE G1: PROJECT KICKOFF — PASSED ==="},

