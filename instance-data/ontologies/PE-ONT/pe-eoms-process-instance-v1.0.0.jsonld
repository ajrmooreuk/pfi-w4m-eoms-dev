      "status": "not_started",
      "sopEntityMapping": ["Search → org-ctx:Product (code, description)", "Filter by market → org-ctx:MarketSegment", "Filter by brand → org-ctx:ProductPortfolio"],
      "stories": [
        {"storyId": "US-2.1.1", "name": "Search products < 200ms response time", "status": "not_started", "testContract": {"type": "performance", "validates": "p95 search latency < 200ms over 7,816 products"}},
        {"storyId": "US-2.1.2", "name": "Filter products by market eligibility", "status": "not_started", "testContract": {"type": "unit", "validates": "Market filter reduces result set correctly"}},
        {"storyId": "US-2.1.3", "name": "Filter by brand, feed type, product state", "status": "not_started", "testContract": {"type": "unit", "validates": "Multi-facet filter intersects correctly"}},
        {"storyId": "US-2.1.4", "name": "See recently used products for quick access", "status": "not_started", "testContract": {"type": "integration", "validates": "Recent products persisted per user; ordered by recency"}}
      ],
      "acceptanceCriteria": "Product search fast, filterable by market/brand/state, recent products accessible"
    },

    {
      "@type": "pe:Activity",
