      "activityName": "Order Export",
      "featureRef": "F3.1",
      "status": "not_started",
      "sopEntityMapping": [
        "Export trigger → sop:OrderValidation[status=passed] → generates export",
        "Export record → sop:validatedOrderToFulfilment bridge (conceptual)",
        "Export tracking → order.exportedAt timestamp"
      ],
      "stories": [
        {"storyId": "US-3.1.1", "name": "Export completed order in clean format", "status": "not_started", "testContract": {"type": "integration", "validates": "Export file generated; contains all order + line data"}},
        {"storyId": "US-3.1.2", "name": "Export multiple orders in batch", "status": "not_started", "testContract": {"type": "integration", "validates": "Batch export produces single file with N orders"}},
        {"storyId": "US-3.1.3", "name": "See which orders have been exported", "status": "not_started", "testContract": {"type": "unit", "validates": "Exported badge shown on order list; filter by exported status"}}
      ],
      "acceptanceCriteria": "Orders exportable individually and in batch; export status tracked"
    },

